{
  "schemaVersion": 1,
  "wikiType": "vault",
  "pythonCommand": null,
  "knownVaults": {},
  "workspace": {
    "root": null,
    "wikiDir": "wiki",
    "scan": {
      "includeExtensions": [
        ".md",
        ".markdown",
        ".txt",
        ".pdf",
        ".docx",
        ".csv",
        ".json",
        ".yaml",
        ".yml"
      ],
      "excludeDirs": [
        ".git",
        ".hg",
        ".svn",
        ".obsidian",
        ".venv",
        "venv",
        "env",
        "__pycache__",
        ".pytest_cache",
        ".mypy_cache",
        ".ruff_cache",
        "node_modules",
        "dist",
        "build",
        ".next",
        ".turbo",
        ".cache",
        "_system",
        "reports",
        "target",
        "vendor"
      ],
      "excludeFileGlobs": [
        "*.lock",
        "package-lock.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "uv.lock",
        "poetry.lock"
      ]
    }
  },
  "conversion": {
    "enabled": false,
    "defaultBackend": "auto",
    "backendOrder": [
      "pymupdf4llm",
      "markitdown"
    ],
    "allowNetwork": false,
    "allowOcr": false,
    "allowLlm": false,
    "allowTranscription": false,
    "allowHostedDocumentIntelligence": false,
    "backends": {
      "pymupdf4llm": {
        "enabled": true,
        "command": null,
        "formats": [
          "pdf"
        ]
      },
      "markitdown": {
        "enabled": true,
        "command": "markitdown",
        "formats": [
          "pdf",
          "docx",
          "pptx",
          "xlsx",
          "html",
          "csv",
          "json",
          "xml",
          "epub"
        ]
      },
      "arxiv2md": {
        "enabled": false,
        "command": null,
        "formats": [
          "pdf"
        ]
      },
      "marker": {
        "enabled": false,
        "command": null,
        "formats": [
          "pdf"
        ]
      }
    }
  }
}
